#lang beagle/clj
(ns fram.fold
  "Replay the append-only assertion log into the current claim set + version.
  Pure projection over assertions; the log bytes are read via fram.rt.")

(require fram.kernel :as k)

(defrecord Assertion [tx :- Int op :- String l :- String p :- String r :- String frame :- String])

(defrecord Fold [claims :- (Vec k/Claim) version :- Int])

;; :tx is DECLARED Int, but read-log passes (:tx m) straight through with no
;; coercion (fram.rt/read-log), so an EDN-valid line lacking :tx (hand-edited,
;; legacy, or partially-written) yields an Assertion whose :tx is nil at runtime.
;; tx-of defaults a missing/non-int :tx to 0 — the SAME guard the coordinator
;; uses on the flat log (`(or (:tx %) 0)`, cnf_coord_daemon.clj) — so a bad line
;; is counted as tx 0 (oldest), never crashing the version high-water scan.
(defn- tx-of [a :- Assertion] :- Int
  (let [t :- Any (:tx a)]
    (if (int? t) t 0)))

;; PUBLIC: the cold write path (main/cmd-set) re-reads the log and uses
;; (max-tx + 1) as the new line's tx, computed from the FRESHEST read right
;; before append — so a later cold `set` observes an earlier one's line and
;; strictly bumps past it. This removes the silent lost-update where two cold
;; sets land the SAME tx on one single-valued key and the fold's >-tie-break
;; just keeps whichever was appended last (finding #17). The fold tie-break
;; itself stays strict-> (deterministic latest-wins); uniqueness is enforced
;; at write time, which is where the collision was actually minted.
(defn max-tx [as :- (Vec Assertion)] :- Int
  (reduce (fn [m :- Int a :- Assertion] :- Int (let [t (tx-of a)] (if (> t m) t m))) 0 as))

;; O(n) fold: collapse to the latest assertion per key in one pass (a hash map),
;; then emit claims. Single-valued predicates key on (l,p) — latest tx wins;
;; multi-valued key on (l,p,r) — latest op (assert/retract) per triple wins.
;; (l/p, and multi-valued r's, are clean refs that never contain the separator.)
(defrecord Latest [tx :- Int op :- String l :- String p :- String r :- String frame :- String])

;; Two-pass cold fold (#2): cardinality is GRAPH-SOURCED — derive each predicate's
;; cardinality from the log's own (P "cardinality" V) claims, so cold replay and the
;; warm store key the SAME way, with no env FRAM_SINGLE_VALUED / hardcoded list
;; (finding #23 dissolved at the root). "cardinality" is itself single-valued, so
;; latest-tx-wins is the right collapse; absent => "multi" (accumulate); a retracted
;; cardinality claim reverts P to multi. This is the same fact schema/cardinality
;; reads on the warm side.
(defn- cardinality-map [asserts :- (Vec Assertion)] :- (Map String String)
  (let [latest (reduce
                (fn [m :- (Map String Latest) a :- Assertion] :- (Map String Latest)
                  (if (= (:p a) "cardinality")
                    (let [k (:l a) prev (get m k) atx (tx-of a)]
                      (if (and (some? prev) (> (:tx prev) atx))
                        m
                        (assoc m k (->Latest atx (:op a) (:l a) (:p a) (:r a) (:frame a)))))
                    m))
                {} asserts)]
    (reduce (fn [acc :- (Map String String) v :- Latest] :- (Map String String)
              (if (= (:op v) "assert") (assoc acc (:l v) (:r v)) acc))
            {} (vec (vals latest)))))

;; single -> key (l,p) (latest tx wins); multi -> key (l,p,r) (accumulate). The
;; separator below is U+0001 (clean refs never contain it) — leave those lines
;; byte-exact.
(defn- key-of [a :- Assertion cmap :- (Map String String)] :- String
  (if (= "single" (get cmap (:p a)))
    (str (:l a) "" (:p a))
    (str (:l a) "" (:p a) "" (:r a))))

(defn- keyed-latest [asserts :- (Vec Assertion)] :- (Map String Latest)
  (let [cmap (cardinality-map asserts)]
    (reduce
     (fn [m :- (Map String Latest) a :- Assertion] :- (Map String Latest)
       (let [k (key-of a cmap)
             prev (get m k)
             atx (tx-of a)]
         (if (and (some? prev) (> (:tx prev) atx))
           m
           (assoc m k (->Latest atx (:op a) (:l a) (:p a) (:r a) (:frame a))))))
     {}
     asserts)))

(defn fold [asserts :- (Vec Assertion)] :- Fold
  ;; Drop torn/partial lines (missing l/p/r) BEFORE keying — the log is appended
  ;; without fsync, so a read caught mid-write can yield an EDN-valid but incomplete
  ;; assertion, and key-of reads :p's cardinality. An incomplete line is an unfinished
  ;; write that must not become a claim. max-tx still counts ALL :tx (version
  ;; high-water mark, kept consistent with the coordinator's seq seeding).
  (let [valid (filterv (fn [a :- Assertion] :- Bool
                         (and (some? (:l a)) (and (some? (:p a)) (some? (:r a))))) asserts)
        keyed (keyed-latest valid)
        claims (reduce
                (fn [acc :- (Vec k/Claim) v :- Latest] :- (Vec k/Claim)
                  (if (= (:op v) "assert")
                    (conj acc (k/->Claim (:l v) (:p v) (:r v)))
                    acc))
                []
                (vec (vals keyed)))]
    (->Fold claims (max-tx asserts))))

;; Current claims as Latest records (assert-op only) — carries `frame`, so a
;; reader can tell coordinator/agent writes from import-derived values.
(defn fold-latest [asserts :- (Vec Assertion)] :- (Vec Latest)
  (filterv (fn [v :- Latest] :- Bool (= (:op v) "assert"))
           (vec (vals (keyed-latest asserts)))))
